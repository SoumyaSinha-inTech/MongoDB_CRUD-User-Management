<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/style2.css">
    <title>Document</title>
</head>

<body>
    <a class="a" href="/">Homepage</a>
    <h2 style="color: white; margin: 10px;">Users</h2>
    <div class="container">
        <%if(users.length>0){%>
            <% users.forEach((user)=>{ %>
                <div class="card">
                    <img src="<%=user.image%>"
                        class="img" alt="">
                    <h4 style="color: white; margin: 10px;"><%=user.name%></h4>
                    <p style="font-size: small; color: rgb(124, 124, 124); margin: -2px 10px;"><%=user.email%></p>
                    <div class="chng">
                        <a class="ab" href="/edit/<%= user._id%>">Edit User</a>
                        <a class="ac" href="/remove/<%= user._id%>">Delete User</a>
                    </div>
                </div>


                <% })} else {%>
                    <div class="info">
                        <p style="color: gray;">no user found!</p>
                    </div>
                    <% } %>
    </div>
</body>

</html>